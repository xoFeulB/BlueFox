{
  "manifest_version": 3,
  "name": "^.,.^ BlueFox",
  "version": "1.0.0",
  "description": "Agile Web Automation Software for Time-Starved Professionals",
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "cookies",
    "tabs",
    "debugger"
  ],
  "background": {
    "service_worker": "/scripts/background.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "/document/newtab/index.html"
  },
  "icons": {
    "16": "/media/icons/16.png",
    "48": "/media/icons/48.png",
    "128": "/media/icons/128.png"
  }
}